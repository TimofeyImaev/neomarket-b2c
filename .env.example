# JWT (общий с другими сервисами секрет, HS256)
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600

# База B2C (корзина, заказы, покупатели). В тестах используется SQLite in-memory.
DATABASE_URL=postgresql+psycopg://b2c:b2c@localhost:5432/b2c

# Интеграция с B2B (источник каталога + reserve/unreserve)
B2B_BASE_URL=http://localhost:8001
B2B_SERVICE_KEY=dev-service-key

# Идемпотентность checkout
IDEMPOTENCY_TTL_SECONDS=3600
